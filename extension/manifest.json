{
  "manifest_version": 3,
  "name": "Buddy",
  "version": "0.1.0",
  "description": "Right-click to save text or links into your own local memory store, then chat with everything you've saved.",
  "permissions": ["contextMenus", "storage", "scripting", "sidePanel", "activeTab"],
  "host_permissions": ["http://localhost/*"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/comment-input.js"],
      "css": ["content/comment-input.css"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "options_page": "options/options.html",
  "action": {
    "default_title": "Open Buddy"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
